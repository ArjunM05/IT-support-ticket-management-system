generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Attachment {
  id          BigInt   @id @default(autoincrement())
  ticketId    String   @db.Uuid @map("ticket_id")
  commentId   String?  @db.Uuid @map("comment_id")
  uploadedBy  String   @db.Uuid @map("uploaded_by")
  fileName    String   @db.VarChar @map("file_name")
  fileUrl     String   @map("file_url")
  mimeType    String   @db.VarChar @map("mime_type")
  fileSize    Int      @map("file_size")
  uploadedAt  DateTime @default(now()) @db.Timestamptz(6) @map("uploaded_at")

  comment     TicketComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  ticket      Ticket         @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  uploader    User           @relation(fields: [uploadedBy], references: [id], onDelete: Cascade)

  @@map("attachments")
}

model Department {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique @db.VarChar
  description String?
  createdAt   DateTime @default(now()) @db.Timestamptz(6) @map("created_at")

  tickets     Ticket[]
  users       User[]

  @@map("departments")
}

model Notification {
  id        BigInt   @id @default(autoincrement())
  userId    String   @db.Uuid @map("user_id")
  title     String   @db.VarChar
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @db.Timestamptz(6) @map("created_at")

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}

model Role {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String?  @unique @db.VarChar
  createdAt DateTime @default(now()) @db.Timestamptz(6) @map("created_at")

  users     User[]

  @@map("roles")
}

model TicketActivityLog {
  id          BigInt         @id @default(autoincrement())
  ticketId    String         @db.Uuid @map("ticket_id")
  performedBy String         @db.Uuid @map("performed_by")
  actionType  TicketActivity @map("action_type")
  oldValue    String?        @map("old_value")
  newValue    String?        @map("new_value")
  createdAt   DateTime       @default(now()) @db.Timestamptz(6) @map("created_at")

  performer   User   @relation(fields: [performedBy], references: [id], onUpdate: Restrict)
  ticket      Ticket @relation(fields: [ticketId], references: [id], onUpdate: Restrict)

  @@map("ticket_activity_logs")
}

model TicketComment {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticketId   String   @db.Uuid @map("ticket_id")
  userId     String   @db.Uuid @map("user_id")
  comment    String
  isInternal Boolean  @default(false) @map("is_internal")
  createdAt  DateTime @default(now()) @db.Timestamptz(6) @map("created_at")

  attachments Attachment[]
  ticket      Ticket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("ticket_comments")
}

model TicketCounter {
  period     String @id
  lastNumber Int    @db.SmallInt @map("last_number")

  @@map("ticket_counters")
}

model Ticket {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticketCode  String         @unique @default(dbgenerated("generate_ticket_code()")) @db.VarChar @map("ticket_code")
  title       String         @db.VarChar
  description String

  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)

  departmentId String? @db.Uuid @map("department_id")
  createdBy    String  @db.Uuid @map("created_by")
  assignedTo   String? @db.Uuid @map("assigned_to")

  resolvedAt DateTime? @db.Timestamptz(6) @map("resolved_at")
  closedAt   DateTime? @db.Timestamptz(6) @map("closed_at")

  createdAt  DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt  DateTime @default(now()) @db.Timestamptz(6) @map("updated_at")

  attachments  Attachment[]
  comments     TicketComment[]
  activityLogs TicketActivityLog[]

  assignee   User?       @relation("AssignedTickets", fields: [assignedTo], references: [id])
  creator    User        @relation("CreatedTickets", fields: [createdBy], references: [id], onDelete: Restrict)
  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetDefault)

  @@index([assignedTo])
  @@index([createdBy])
  @@index([priority])
  @@index([status])

  @@map("tickets")
}

model User {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fullName     String    @db.VarChar @map("full_name")
  email        String    @unique @db.VarChar
  passwordHash String    @map("password_hash")

  roleId       String    @db.Uuid @map("role_id")
  departmentId String?   @db.Uuid @map("department_id")

  isActive     Boolean   @default(true) @map("is_active")

  createdAt    DateTime  @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt    DateTime? @default(now()) @db.Timestamptz(6) @map("updated_at")

  attachments  Attachment[]
  notifications Notification[]
  activityLogs TicketActivityLog[]
  comments     TicketComment[]

  assignedTickets Ticket[] @relation("AssignedTickets")
  createdTickets  Ticket[] @relation("CreatedTickets")

  department Department? @relation(fields: [departmentId], references: [id])
  role       Role        @relation(fields: [roleId], references: [id], onDelete: NoAction)

  @@map("users")
}

enum TicketActivity {
  TICKET_CREATED
  STATUS_CHANGED
  ASSIGNED_CHANGED
  COMMENT_ADDED
  TICKET_REOPENED

  @@map("ticket_activity")
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL

  @@map("ticket_priority")
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
  REOPENED

  @@map("ticket_status")
}