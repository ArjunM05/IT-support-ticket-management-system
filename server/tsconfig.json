{
  "compilerOptions": {
    "target": "ES2020",
    "module": "node16",
    "moduleResolution": "nodenext",

    "rootDir": ".",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,
    "verbatimModuleSyntax": false,

    "types": ["node"],
    "skipLibCheck": true
  },

  "include": [
    "src"
, "prisma.config.ts"  ],

  "exclude": [
    "node_modules",
    "dist"
  ]
}